{
  "name": "cheffolio",
  "version": "0.1.0",
  "description": "A minimal, shadcn/ui-inspired dev portfolio.",
  "homepage": "https://cheffolio.vercel.app",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chef0111/cheffolio.git"
  },
  "scripts": {
    "dev": "portless cheffolio next dev",
    "build": "next build",
    "start": "portless cheffolio next start",
    "next": "next build && portless cheffolio next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "check-types": "tsc --noEmit --pretty",
    "upgrade:next": "npm exec @next/codemod@latest upgrade latest",
    "upgrade:tailwind": "npm exec @tailwindcss/upgrade@latest",
    "prepare": "husky"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-hotkeys": "^0.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "geist": "^1.7.0",
    "libphonenumber-js": "^1.12.40",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "schema-dts": "^1.1.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "tw-animate-css": "^1.4.0",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@toolwind/corner-shape": "^0.0.8-3",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.183.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rehype-external-links": "^3.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "shadcn": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "unist-builder": "3.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "**/*.{html,json,css,scss,md,mdx}": [
      "prettier --write"
    ]
  }
}
